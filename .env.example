# Supabase configuration
# Find these in your Supabase project: Settings -> API
# Copy this file to .env.local and fill in the values, then restart `npm run dev`.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Use your publishable key (sb_publishable_...) — or the legacy anon key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# AI insights for the Meesho Overview tab (either provider works; OpenRouter is tried first)
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=anthropic/claude-3.5-haiku
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-latest
